{
  "productName": "XRPL Creator Capsule",
  "version": "1.0.0-rc.2",
  "identifier": "com.mcptoolshop.capsule-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": {
      "resources/*": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "windows": [
      {
        "title": "XRPL Creator Capsule",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$HOME/**", "$DOCUMENT/**", "$DESKTOP/**", "$APPDATA/**", "$APPCONFIG/**", "$APPLOCALDATA/**"],
        "deny": []
      }
    },
    "dialog": {
      "open": true,
      "save": true
    },
    "shell": {
      "open": true
    }
  }
}
